{
  "name": "little-net-game",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:worker": "wrangler dev --config realtime-worker/wrangler.jsonc",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "npm run test:legacy",
    "test:legacy": "tsx --test src/lib/**/*.test.ts",
    "test:unit": "vitest run",
    "test:worker": "vitest run realtime-worker/test/room-engine.test.ts realtime-worker/test/match-engine.test.ts",
    "test:all": "npm run test:legacy && npm run test:unit && npm run test:worker",
    "typegen:worker": "wrangler types --config realtime-worker/wrangler.jsonc"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "next": "16.2.3",
    "phaser": "^3.90.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.70",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.3",
    "jsdom": "^26.0.0",
    "tsx": "^4.20.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.13.2",
    "typescript": "^5"
  }
}
